# ----------------------------------------------------------------
# .gitignore for a standard Python project
# ----------------------------------------------------------------

# Virtual Environments
# Ignore the virtual environment folder. Common names are .venv, venv, or env.
# The trailing slash ensures we only match directories.
.venv*/
venv/
env/

# Python generated files
# Ignore caches and compiled files that Python generates automatically.
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / packaging
# Ignore build artifacts and distribution folders.
.eggs/
*.egg-info/
dist/
build/
*.egg

# Environment variables
# Ignore files containing sensitive data like API keys or database passwords.
# NEVER commit your environment variables!
.env

# IDE / Editor-specific files
# Ignore configuration files from common editors.
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Archive (legacy code, not public).
# Use `_archive/*` (not `_archive/`) so the directory itself isn't excluded —
# that lets us re-include the consolidated 2026-04 research-report archive,
# which is the audit trail cited by docs/research_reports/FINDINGS_LEDGER.md
# and must stay in version control.
_archive/*
!_archive/research_reports_2026-04/

# Cache dirs
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Claude Code — keep agents and rules, ignore local settings and plans
.claude/settings.local.json
.claude/plans/

# Gemini config
.gemini/prompts/

# trace_logger vendor copies staged by service deploy.sh scripts
**/_trace_logger_vendor/

# dbt — incomplete/stale project, not in use. Ignore the whole directory.
dbt/
.user.yml
