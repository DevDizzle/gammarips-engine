# Template for dbt/profiles.yml (the real file is gitignored — it is the only
# secret/connection file in the dbt project). Copy to dbt/profiles.yml and fill in.
#
#   cp profiles.yml.example profiles.yml
#
# `dev`  — local development against your own gcloud OAuth (Application Default Creds).
#          Run `gcloud auth application-default login` once.
# `ci`   — service-account JSON injected via the GCP_SA_KEY env var (GitHub Actions).
#          Writes to an isolated CI dataset so PR builds never touch prod marts.

gammarips:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: oauth
      project: profitscout-fida8
      dataset: profitscout_dbt
      location: us-central1
      threads: 4
      priority: interactive

    ci:
      type: bigquery
      method: service-account-json
      keyfile_json: "{{ env_var('GCP_SA_KEY') | as_native }}"
      project: profitscout-fida8
      dataset: profitscout_dbt_ci
      location: us-central1
      threads: 4

    # prod — used by the dbt-runner Cloud Run service. method: oauth resolves to
    # the Cloud Run default compute SA via ADC (no key/secret).
    prod:
      type: bigquery
      method: oauth
      project: profitscout-fida8
      dataset: profitscout_dbt
      location: us-central1
      threads: 4
